{
  "name": "@jeansoft/cocos-atlas-tool",
  "version": "0.2.6",
  "description": "解析 Cocos Creator 图集(Atlas) plist 资源的工具库",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "cocos",
    "cocos2d-x",
    "cocos-creator",
    "atlas",
    "plist",
    "sprite-sheet",
    "texturepacker"
  ],
  "author": "jeansoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeanhwea/cocos-atlas-tool.git"
  },
  "bugs": {
    "url": "https://github.com/Jeanhwea/cocos-atlas-tool/issues"
  },
  "homepage": "https://github.com/Jeanhwea/cocos-atlas-tool#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "peerDependencies": {
    "sharp": "^0.33.5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.9.4",
    "sharp": "^0.33.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "plist": "5.0.0"
  }
}
